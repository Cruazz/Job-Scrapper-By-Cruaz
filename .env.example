# Scraping
REQUEST_DELAY=1.5
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# Sources (enable/disable)
SCRAPE_INDEED=true
SCRAPE_LINKEDIN=true
SCRAPE_WWR=true

# Filtering
KEYWORDS=python,backend,api,django,fastapi
LOCATIONS=remote,new york
MIN_SALARY=80000
SENIORITY=mid,senior

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=app-specific-password
TO_EMAIL=your.email@gmail.com

# System
LOG_LEVEL=INFO
DATABASE_PATH=data/jobs.db
